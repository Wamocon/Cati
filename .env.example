# Root repository tooling only.
# Copy to .env.local only when running repository-level automation locally.
# The Next.js app has its own template at apps/web/.env.example.

# Jira / Xray sync
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=CATI
JIRA_DRY_RUN=1
JIRA_SKIP_ATTACHMENTS=1
JIRA_SKIP_QA_ATTACHMENTS=1
XRAY_BASE_URL=
XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=

# Supabase CLI / cloud import tooling
SUPABASE_PROJECT_REF=
SUPABASE_DB_URL=
SUPABASE_DB_PASSWORD=
SUPABASE_IMPORT_GROUP_SIZE=50

# Local browser QA tooling
UI_AUDIT_BASE_URL=http://127.0.0.1:3104
UI_AUDIT_OUTPUT_DIR=quality/results/ui-audit
PLAYWRIGHT_BROWSERS_PATH=.tmp/ms-playwright
