# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Twenty CRM (self-hosted)
TWENTY_API_URL=https://crm.yourdomain.com
TWENTO_API_KEY=your-twenty-api-key

# WhatsApp contact for the landing-page concierge (site management line).
# International format without "+" or spaces, e.g. 905321234567. The committed
# placeholder is intentionally invalid so the demo never messages a real number.
NEXT_PUBLIC_WHATSAPP_NUMBER=900000000000

# Local/on-prem AI service
AI_API_URL=https://your-ai-host.example.com/api
AI_API_KEY=your-ai-api-key
AI_CHAT_COMPLETIONS_PATH=/chat/completions
AI_MODEL_FAST=sokrates-fast
AI_MODEL_REASONING=qwen3.6-35b
AI_MODEL_GERMAN_COPY=gemma4-31b
AI_MODEL_PRO=sokrates-pro
