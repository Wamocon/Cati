# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only HMAC key for public QR intake, private tracking receipts, and
# abuse fingerprints. Generate an independent high-entropy value.
PUBLIC_REPORT_SECURITY_SECRET=replace-with-an-independent-long-random-secret

# Dedicated server-only registration peppers. Use independent random values;
# do not reuse or derive these from the Supabase service-role key.
REGISTRATION_IDENTITY_PEPPER=replace-with-a-long-random-secret
REGISTRATION_RECEIPT_PEPPER=replace-with-another-long-random-secret

# Private document storage
DOCUMENT_STORAGE_MODE=supabase
SUPABASE_DOCUMENT_BUCKET=cati-documents

# Twenty CRM (self-hosted)
TWENTY_API_URL=https://crm.yourdomain.com
TWENTY_API_KEY=your-twenty-api-key

# Local/on-prem AI service
AI_API_URL=https://your-ai-host.example.com/api
AI_API_KEY=your-ai-api-key
AI_CHAT_COMPLETIONS_PATH=/chat/completions
AI_MODEL_FAST=sokrates-fast
AI_MODEL_REASONING=qwen3.6-35b
AI_MODEL_GERMAN_COPY=gemma4-31b
AI_MODEL_PRO=sokrates-pro

# Public concierge and provider-ready identity verification
NEXT_PUBLIC_WHATSAPP_NUMBER=900000000000
IDV_API_URL=https://your-idv-provider.example.com/api
IDV_API_KEY=your-idv-provider-key
IDV_VERIFY_PATH=/verify
IDV_PROVIDER=default

# Controlled demo access profiles
# Production deployments never permit no-password role switching, regardless
# of these flags. A remote preview may opt in only when it is synthetic,
# isolated from every Supabase data plane, and all three flags are true.
ENABLE_ACCESS_PROFILES=false
CATI_ALLOW_REMOTE_ACCESS_PROFILES=false
CATI_DEMO_DATA_ISOLATED=false
