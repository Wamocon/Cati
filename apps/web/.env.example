# Supabase - server/runtime
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
SUPABASE_DOCUMENT_BUCKET=cati-documents

# Supabase - browser client
# These are intentionally public because browser auth/realtime needs them.
# Do not put service-role keys or provider secrets behind NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Access-profile QA flags
# Do not create NEXT_PUBLIC_ENABLE_ACCESS_PROFILES in Vercel production.
ENABLE_ACCESS_PROFILES=false
ACCESS_PROFILE_ROLE=manager
CATI_ALLOW_REMOTE_ACCESS_PROFILES=false

# Twenty CRM (self-hosted)
TWENTY_API_URL=https://crm.yourdomain.com
TWENTY_API_KEY=your-twenty-api-key

# Local/on-prem AI service
AI_API_URL=https://your-ai-host.example.com/api
AI_API_KEY=your-ai-api-key
AI_CHAT_COMPLETIONS_PATH=/chat/completions
AI_MODEL_FAST=sokrates-fast
AI_MODEL_REASONING=qwen3.6-35b
AI_MODEL_GERMAN_COPY=gemma4-31b
AI_MODEL_PRO=sokrates-pro

# Public concierge and provider-ready identity verification
NEXT_PUBLIC_WHATSAPP_NUMBER=900000000000
IDV_API_URL=https://your-idv-provider.example.com/api
IDV_API_KEY=your-idv-provider-key
IDV_VERIFY_PATH=/verify
IDV_PROVIDER=default
