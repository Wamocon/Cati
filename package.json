{
  "name": "cati",
  "private": true,
  "version": "2.0.0",
  "description": "1Çatı Property Management Platform — pitch + Next.js CRM application",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "browser:audit": "node scripts/browser-audit.mjs",
    "jira:sync": "node scripts/jira-xray-sync.mjs",
    "jira:github-main-sync": "node scripts/jira-github-main-update.mjs",
    "phase:harness": "node scripts/phase-harness.mjs",
    "phase:06-09": "node scripts/phase-06-09-harness.mjs --max-attempts 2",
    "phase:smoke": "node scripts/phase-harness.mjs --profile smoke --max-attempts 2",
    "phase:full": "node scripts/phase-harness.mjs --profile full --max-attempts 2",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status",
    "supabase:reset": "npx supabase db reset",
    "supabase:types": "npx supabase gen types typescript --local --schema public > apps/web/lib/database.types.ts",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
